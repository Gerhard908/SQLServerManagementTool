@model SQLServerManagementTool.Web.ViewModels.Connection.ConnectionViewModel

@{
    ViewData["Title"] = "Connect";
}

<div class="card">

    <h1>Create Connection</h1>

    <p>

        Enter the SQL Server or Azure SQL connection details.

    </p>

    <form asp-action="Connect" method="post">

        <div class="form-group">

            <label asp-for="ConnectionType"></label>

            <select asp-for="ConnectionType" class="form-control">

                <option value="SQLServer">SQL Server</option>
                <option value="AzureSQL">Azure SQL</option>

            </select>

        </div>

        <div class="form-group">

            <label asp-for="ServerName"></label>

            <input asp-for="ServerName" class="form-control" />

            <span asp-validation-for="ServerName"
                  class="validation-error"></span>

        </div>

        <div class="form-group">

            <label asp-for="DatabaseName"></label>

            <input asp-for="DatabaseName" class="form-control" />

        </div>

        <div class="form-group">

            <input asp-for="UseWindowsAuthentication" />

            <label asp-for="UseWindowsAuthentication"></label>

        </div>

        <div class="form-group">

            <label asp-for="Username"></label>

            <input asp-for="Username"
                   class="form-control" />

        </div>

        <div class="form-group">

            <label asp-for="Password"></label>

            <input asp-for="Password"
                   class="form-control" />

        </div>

        <button class="primary-button"
                type="submit">

            Test Connection

        </button>

    </form>

</div>