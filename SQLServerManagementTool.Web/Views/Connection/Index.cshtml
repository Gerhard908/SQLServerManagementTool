@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard">

    <div class="dashboard-main">

        <section class="card welcome-card">

            <h1>SQL Server Management Tool</h1>

            <p>
                SQL Server Management Tool is a lightweight database management
                application designed for SQL Server and Azure SQL.
            </p>

            <p>
                Connect to a server to browse databases, inspect tables,
                manage data and administer your environment through a
                modern, intuitive interface.
            </p>

        </section>

        <section class="dashboard-actions">

            <div class="card action-card">

                <h2>SQL Server</h2>

                <p>Connect to an on-premises SQL Server instance.</p>

            </div>

            <div class="card action-card">

                <h2>Azure SQL</h2>

                <p>Connect securely to Azure SQL Database.</p>

            </div>

        </section>

    </div>

    <aside class="dashboard-sidebar">

        <section class="card status-card">

            <h2>Connection Status</h2>

            <table>

                <tr>
                    <td>Status</td>
                    <td>Not Connected</td>
                </tr>

                <tr>
                    <td>Provider</td>
                    <td>None</td>
                </tr>

                <tr>
                    <td>Server</td>
                    <td>N/A</td>
                </tr>

                <tr>
                    <td>Database</td>
                    <td>N/A</td>
                </tr>

            </table>

        </section>

    </aside>

</div>